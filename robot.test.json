{
  "version": "2",
  "robot": {
    "name": "lights",
    "description": "gorai-lights in test mode — simulated GPS and simulated Tasmota light, no hardware"
  },
  "nats": {
    "embedded": true,
    "url": "nats://localhost:4222"
  },
  "dashboard": { "enabled": false },
  "components": [
    {
      "name": "gps",
      "type": "gps",
      "model": "nmea",
      "attributes": {
        "device": "/dev/gps-sim",
        "baud_rate": 9600
      }
    }
  ],
  "services": [
    {
      "name": "porch-light",
      "type": "tasmota",
      "model": "sim",
      "attributes": { "device": "porch" }
    },
    {
      "name": "lights",
      "type": "scheduler",
      "model": "lights",
      "attributes": {
        "gps": "gps",
        "reconcile_interval": "60s",
        "lights": [
          {
            "name": "porch",
            "device": "porch",
            "schedule": [
              { "on": "sunset-00:15", "off": "23:30" },
              { "on": "05:30", "off": "sunrise+00:10" }
            ]
          }
        ]
      }
    }
  ],
  "discovery": {
    "enabled": false
  }
}
