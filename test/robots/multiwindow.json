{
  "version": "2",
  "robot": { "name": "lights", "description": "Test fixture: multiple windows per light per day" },
  "nats": { "embedded": true, "url": "nats://127.0.0.1:14803" },
  "dashboard": { "enabled": false },
  "components": [
    { "name": "gps", "type": "gps", "model": "inject", "attributes": {} }
  ],
  "services": [
    { "name": "porch-light", "type": "tasmota", "model": "sim", "attributes": { "device": "porch" } },
    { "name": "lights", "type": "scheduler", "model": "lights",
      "attributes": {
        "timezone": "UTC",
        "lights": [
          { "name": "porch", "device": "porch",
            "schedule": [ { "on": "06:00", "off": "09:00" }, { "on": "17:00", "off": "22:00" }, { "on": "22:00", "off": "24:00" } ] }
        ]
      } }
  ],
  "discovery": { "enabled": false }
}
