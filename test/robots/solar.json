{
  "version": "2",
  "robot": { "name": "lights", "description": "Test fixture: solar windows with location fallback" },
  "nats": { "embedded": true, "url": "nats://127.0.0.1:14802" },
  "dashboard": { "enabled": false },
  "components": [
    { "name": "gps", "type": "gps", "model": "inject",
      "attributes": { "initial_latitude": 37.7749, "initial_longitude": -122.4194, "continuous": true } }
  ],
  "services": [
    { "name": "porch-light", "type": "tasmota", "model": "sim", "attributes": { "device": "porch" } },
    { "name": "lights", "type": "scheduler", "model": "lights",
      "attributes": {
        "gps": "gps",
        "location": { "latitude": 37.7749, "longitude": -122.4194 },
        "lights": [
          { "name": "porch", "device": "porch",
            "schedule": [ { "on": "sunset-00:15", "off": "23:30" }, { "on": "05:30", "off": "sunrise+00:10" } ] }
        ]
      } }
  ],
  "discovery": { "enabled": false }
}
