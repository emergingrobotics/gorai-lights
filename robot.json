{
  "version": "2",
  "robot": {
    "name": "lights",
    "description": "GPS-located, timezone-aware Tasmota light controller (example robot)"
  },
  "nats": {
    "embedded": true,
    "url": "nats://localhost:4222"
  },
  "components": [
    {
      "name": "gps",
      "type": "gps",
      "model": "nmea",
      "attributes": {
        "device": "/dev/ttyUSB0",
        "baud_rate": 9600
      }
    }
  ],
  "services": [
    {
      "name": "tasmota",
      "type": "tasmota",
      "model": "controller",
      "attributes": {
        "devices": [
          { "name": "porch", "type": "sonoff", "address": "192.168.1.50" }
        ]
      }
    },
    {
      "name": "lights",
      "type": "scheduler",
      "model": "lights",
      "attributes": {
        "gps": "gps",
        "reconcile_interval": "60s",
        "lights": [
          {
            "name": "porch",
            "device": "porch",
            "schedule": [
              { "on": "sunset-00:15", "off": "23:30" },
              { "on": "05:30", "off": "sunrise+00:10" }
            ]
          }
        ]
      }
    }
  ],
  "discovery": {
    "enabled": false
  }
}
